# New-API environment variables
# Copy this file to new-api.env and customize.
#
# Full reference: see new-api upstream documentation.
# These env vars are injected into the New-API container.

# ============================================================
# Database — PostgreSQL connection string
# MUST match POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB
# from common.env. Hostname is the compose service name.
# ============================================================
SQL_DSN=postgresql://newapi:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/newapi

# ============================================================
# Redis — connection string for caching and rate limiting
# MUST match REDIS_PASSWORD from common.env.
# ============================================================
REDIS_CONN_STRING=redis://:CHANGE_ME_REDIS_PASSWORD_HERE@redis:6379/0

# ============================================================
# Session — REQUIRED for production
# Generate with: openssl rand -hex 32
# All New-API nodes must share the same secret.
# ============================================================
SESSION_SECRET=CHANGE_ME_RANDOM_SESSION_SECRET

# ============================================================
# General settings
# ============================================================
TZ=UTC

# Enable error logging to file (logs go to /app/logs via --log-dir)
ERROR_LOG_ENABLED=true

# Batch update mode: groups database writes for better performance
BATCH_UPDATE_ENABLED=true

# Port New-API listens on (must match docker-compose healthcheck
# and nginx upstream definition)
# PORT=3000

# ============================================================
# Timeouts — tune for your use case
# ============================================================
# Global request timeout in seconds (0 = no limit)
# RELAY_TIMEOUT=0

# Streaming idle timeout in seconds (time between SSE chunks
# before the connection is considered stale)
# STREAMING_TIMEOUT=300

# ============================================================
# Multi-node deployment (optional)
# ============================================================
# NODE_TYPE=master
# SYNC_FREQUENCY=60

# ============================================================
# Frontend customization (optional)
# ============================================================
# FOOTER_HTML=Powered by Control Plane
# SYSTEM_NAME=AI Gateway

# ============================================================
# OAuth providers (optional — for user login)
# ============================================================
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# OIDC_WELL_KNOWN=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
