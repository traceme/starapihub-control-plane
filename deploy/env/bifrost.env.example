# Bifrost environment variables
# Copy this file to bifrost.env and customize.
#
# Full reference: bifrost/AGENTS.md and bifrost/transports/config.schema.json
# These env vars are injected into the Bifrost container.

# ============================================================
# Server — HTTP transport listener
# Must match the base URL used in New-API channel configs
# (i.e., New-API channels point to http://bifrost:8080)
# ============================================================
PORT=8080
HOST=0.0.0.0

# ============================================================
# Logging
# ============================================================
# Output format: "json" for structured logging, "pretty" for dev
LOG_STYLE=json
# Levels: debug, info, warn, error
LOG_LEVEL=info

# ============================================================
# App data directory — where config.json and config.db live
# This is the Bifrost working directory inside the container.
# The docker-compose volume mounts bifrost-data here.
# ============================================================
# APP_DIR=/app/data

# ============================================================
# Provider API keys
# These can be referenced in config.json via "env.VAR_NAME" syntax.
# Only set the ones you need.
# ============================================================
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# OPENAI_API_KEY=sk-xxxxx
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ============================================================
# Bifrost admin auth (optional)
# If enabled in config.json governance.auth_config, these
# credentials protect the Bifrost management API.
# In our deployment, Bifrost is internal-only (core-net),
# so auth is optional but recommended for defense-in-depth.
# ============================================================
# BIFROST_ADMIN_USER=admin
# BIFROST_ADMIN_PASS=CHANGE_ME

# ============================================================
# Telemetry / observability (optional)
# ============================================================
# Prometheus labels attached to all metrics
# PROMETHEUS_LABELS=env:production,stack:control-plane

# OpenTelemetry endpoint (if using the otel plugin)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
