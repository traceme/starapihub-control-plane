# ClewdR instance 2 environment variables
# Copy this file to clewdr-2.env and customize.
#
# IMPORTANT: Use a DIFFERENT Claude.ai account/cookie than instance 1.
# See clewdr-1.env.example for full documentation of all settings.

# ============================================================
# Server
# ============================================================
CLEWDR_IP=0.0.0.0
CLEWDR_PORT=8484

# CLEWDR_PASSWORD=your-api-password-for-instance-2
# CLEWDR_ADMIN_PASSWORD=your-admin-password-for-instance-2

# ============================================================
# Updates (disable in Docker)
# ============================================================
CLEWDR_CHECK_UPDATE=false
CLEWDR_AUTO_UPDATE=false

# ============================================================
# Network
# ============================================================
# CLEWDR_PROXY=socks5://proxy-host:1080

# ============================================================
# Cookie behavior
# ============================================================
CLEWDR_SKIP_RATE_LIMIT=true
# CLEWDR_SKIP_RESTRICTED=false
# CLEWDR_SKIP_NON_PRO=false
# CLEWDR_MAX_RETRIES=5

# ============================================================
# COOKIE SETUP: docker logs cp-clewdr-2 for admin password,
# then follow config/clewdr/instances.example.md
# ============================================================
