# Common environment variables used by docker-compose.yml
# Copy this file to common.env and customize.
#
# These variables are interpolated directly by docker compose
# (they are NOT passed into containers as env vars).

# ============================================================
# Version Pinning — change these to upgrade upstream components
# Pin to specific tags in production. Use 'latest' only for dev.
# See docs/upgrade-strategy.md for the upgrade workflow.
#
# Tested image digests (as of 2026-03-20):
#   calciumion/new-api@sha256:648622b40a8275ed45eb988b0df3f0a548241b4eea5e2367ad377cd892d31b4a
#   maximhq/bifrost@sha256:0b67d35ef9c71d09c3ccc3eeb844f91e98b1cacd38b004e00c32921e26ad7350
# ============================================================
NEWAPI_VERSION=latest
BIFROST_VERSION=latest

# ============================================================
# Appliance Mode — determines how version/mode are reported
# Set to "upstream" for unpatched images, "appliance" for patched.
# Controls `starapihub version` and /api/version output.
# ============================================================
# NEWAPI_IMAGE=calciumion/new-api       # upstream (default)
# NEWAPI_IMAGE=starapihub/new-api       # appliance (patched)
STARAPIHUB_MODE=upstream

# ClewdR image — no public Docker image exists.
# Build locally: bash scripts/build-clewdr-image.sh
# Or push to a private registry: bash scripts/build-clewdr-image.sh --push ghcr.io/yourorg/clewdr
# Then set CLEWDR_IMAGE to the registry path:
CLEWDR_IMAGE=clewdr:local

# ============================================================
# Public Ingress — ports published by the nginx container
# ============================================================
PUBLIC_HTTPS_PORT=443
PUBLIC_HTTP_PORT=80

# Path to directory containing TLS cert and key files.
# Expected files: server.crt (full chain), server.key (private key)
TLS_CERT_DIR=./certs

# ============================================================
# PostgreSQL (used by New-API)
# IMPORTANT: After first deploy, changing these requires
# manual database migration or volume recreation.
# ============================================================
POSTGRES_USER=newapi
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=newapi

# ============================================================
# Redis (used by New-API for caching and rate limiting)
# ============================================================
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE
