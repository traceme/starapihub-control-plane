# ClewdR instance 1 environment variables
# Copy this file to clewdr-1.env and customize.
#
# Each ClewdR instance should use a SEPARATE Claude.ai cookie/account
# to spread load and reduce per-account rate limiting.
#
# ClewdR uses the CLEWDR_ prefix for all env vars. Config is loaded
# from env vars and clewdr.toml (env vars take precedence).
# Reference: clewdr/src/config/clewdr_config.rs

# ============================================================
# Server (requires container restart to change)
# ============================================================
CLEWDR_IP=0.0.0.0
CLEWDR_PORT=8484

# API password for inference endpoints (/v1/messages, /v1/chat/completions)
# Clients use this as Bearer token. Auto-generated if empty.
# Bifrost provider config must use this value as the API key.
# CLEWDR_PASSWORD=your-api-password-for-instance-1

# Admin dashboard password for the web UI at http://host:8484
# Auto-generated if empty — check container logs on first boot.
# CLEWDR_ADMIN_PASSWORD=your-admin-password-for-instance-1

# ============================================================
# Updates (disable in Docker — manage via image version pins)
# ============================================================
CLEWDR_CHECK_UPDATE=false
CLEWDR_AUTO_UPDATE=false

# ============================================================
# Network (hot-reloadable — changes take effect without restart)
# ============================================================
# Outbound proxy for reaching Claude.ai (if server IP is blocked)
# CLEWDR_PROXY=socks5://proxy-host:1080

# Reverse proxy URL override (for advanced setups)
# CLEWDR_RPROXY=https://custom-claude-endpoint.example.com

# ============================================================
# Cookie behavior (hot-reloadable)
# ============================================================
# Skip rate-limit cooldown periods (try next cookie instead of waiting)
CLEWDR_SKIP_RATE_LIMIT=true

# Skip cookies that have received restriction warnings
# CLEWDR_SKIP_RESTRICTED=false

# Skip non-Pro cookies (only use Pro account cookies)
# CLEWDR_SKIP_NON_PRO=false

# Maximum retry attempts per request across cookies
# CLEWDR_MAX_RETRIES=5

# ============================================================
# API behavior (hot-reloadable)
# ============================================================
# Preserve chat conversations on Claude.ai (instead of deleting)
# CLEWDR_PRESERVE_CHATS=false

# Enable web search in Claude.ai conversations
# CLEWDR_WEB_SEARCH=false

# Use real role names (user/assistant) in conversations
# CLEWDR_USE_REAL_ROLES=true

# ============================================================
# Filesystem
# ============================================================
# Disable filesystem writes (all config in memory only)
# CLEWDR_NO_FS=false

# Enable logging to file
# CLEWDR_LOG_TO_FILE=false

# ============================================================
# COOKIE SETUP
# Cookies are NOT set via environment variables.
# After first boot:
#   1. Get admin password: docker logs cp-clewdr-1 2>&1 | head -20
#   2. Access admin UI (port-forward: ssh -L 18484:127.0.0.1:18484 server)
#      OR temporarily uncomment ports in docker-compose.yml
#   3. Navigate to Claude tab -> paste browser cookie
#   4. Verify cookie shows as healthy
# See config/clewdr/instances.example.md for the full checklist.
# ============================================================
