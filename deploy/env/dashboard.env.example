# Dashboard (Control Plane UI) environment variables
# Copy this file to dashboard.env and customize.

# ============================================================
# Authentication — REQUIRED
# Generate with: openssl rand -hex 32
# This token is used to access the dashboard API and UI.
# ============================================================
DASHBOARD_TOKEN=CHANGE_ME_DASHBOARD_TOKEN

# ============================================================
# Service URLs — defaults work with docker-compose networking
# ============================================================
NEWAPI_URL=http://new-api:3000
# Required if the dashboard should apply live model delete cleanup immediately
# (used by DELETE /api/models/{id} to update New-API channels/pricing after
# policy files are changed).
# NEWAPI_ADMIN_TOKEN=CHANGE_ME_NEWAPI_ADMIN_TOKEN
# Optional; defaults to 1 for the local appliance.
# NEWAPI_ADMIN_USER_ID=1
BIFROST_URL=http://bifrost:8080

# Comma-separated ClewdR instance URLs
CLEWDR_URLS=http://clewdr-1:8484,http://clewdr-2:8484,http://clewdr-3:8484

# Comma-separated admin tokens for each ClewdR instance
# Get from: docker logs cp-clewdr-N 2>&1 | grep "Web Admin Password"
# CLEWDR_ADMIN_TOKENS=token1,token2,token3

# ============================================================
# Server
# ============================================================
DASHBOARD_PORT=8090
DB_PATH=/app/data/dashboard.db
POLICIES_DIR=/app/policies

# ============================================================
# Appliance Mode — REQUIRED for accurate version reporting
# Valid values: "upstream" or "appliance"
# Set to "appliance" when using the patched New-API image.
# If unset, /api/version and `starapihub version` report mode=unknown.
# ============================================================
STARAPIHUB_MODE=upstream

# ============================================================
# Alerting (optional — recommended for production)
# ============================================================
# Webhook URL for alert notifications. The dashboard POSTs JSON
# alerts here (see docs/alert-model.md for payload shape).
# Accepts any HTTP endpoint: Slack, PagerDuty, custom receiver.
# If unset, alerts are stored in the dashboard DB but not pushed.
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# ============================================================
# Log tailing
# ============================================================
NGINX_LOG_PATH=/var/log/nginx/access.log
